# MySQL
MYSQL_DATABASE=jobpilot_ai
MYSQL_USER=jobpilot
MYSQL_PASSWORD=jobpilot_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=jobpilot_questions

# Backend
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
DB_HOST=localhost
