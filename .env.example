DB_NAME=jobpilot_ai
DB_USERNAME=jobpilot
DB_PASSWORD=jobpilot_password
REDIS_HOST=localhost
QDRANT_HOST=http://localhost:6333
JWT_SECRET=replace-with-at-least-32-characters-secret
JWT_EXPIRATION_MINUTES=1440

# AI providers
AI_PROVIDER=mock
AI_MODEL=mock-chat
AI_API_KEY=
AI_BASE_URL=
